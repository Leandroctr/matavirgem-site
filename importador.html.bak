<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Importador - Firebase</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Outfit', sans-serif;
      background: linear-gradient(135deg, #1b3a22 0%, #2c5c3a 100%);
      min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 1rem;
    }
    .card {
      background: #f6f2ea; border-radius: 12px; padding: 2rem;
      max-width: 600px; width: 100%; box-shadow: 0 20px 60px rgba(0,0,0,.3);
    }
    h1 {
      font-family: 'Cormorant Garamond', serif; font-size: 2rem;
      color: #1b3a22; margin-bottom: .5rem;
    }
    .subtitle {
      font-size: .8rem; letter-spacing: .1em; text-transform: uppercase;
      color: #c8a84b; margin-bottom: 1.5rem;
    }
    textarea {
      width: 100%; padding: 1rem; border: 1px solid rgba(200,168,75,.3);
      border-radius: 6px; font-family: monospace; font-size: .9rem;
      min-height: 300px; resize: vertical; color: #252520; margin-bottom: 1rem;
    }
    textarea:focus { outline: none; border-color: #c8a84b; box-shadow: 0 0 0 3px rgba(200,168,75,.1); }
    .btn {
      width: 100%; padding: 1rem;
      background: linear-gradient(135deg, #1b3a22 0%, #2c5c3a 100%);
      color: #fff; border: none; border-radius: 6px; font-size: .85rem;
      letter-spacing: .1em; text-transform: uppercase; cursor: pointer;
      transition: all .3s; font-weight: 500; margin-bottom: 1rem;
    }
    .btn:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(27,58,34,.3); }
    .btn:disabled { opacity: .6; cursor: not-allowed; }
    .status {
      padding: 1rem; border-radius: 6px; margin-bottom: 1rem;
      font-size: .9rem; display: none;
    }
    .status.show { display: block; }
    .status-success {
      background: rgba(37,211,102,.1); border: 1px solid rgba(37,211,102,.3); color: #1a7d4e;
    }
    .status-error {
      background: rgba(214,69,69,.1); border: 1px solid rgba(214,69,69,.3); color: #9a2c2c;
    }
    .status-loading {
      background: rgba(200,168,75,.1); border: 1px solid rgba(200,168,75,.3); color: #7a5230;
    }
  </style>
</head>
<body>

  <div class="card">
    <h1>Importador de Dados</h1>
    <div class="subtitle">Firebase Firestore</div>

    <textarea id="jsonInput" placeholder="Cole seu dados.json aqui"></textarea>

    <button class="btn" onclick="importar()" id="btn">📥 Importar</button>
    <div id="status" class="status"></div>
  </div>

  <script type="module">
    import { initializeApp } from "https://www.gstatic.firebasecdn.com/9.22.2/firebase-app.js";
    import { getFirestore, collection, doc, setDoc, deleteDoc, getDocs } from "https://www.gstatic.firebasecdn.com/9.22.2/firebase-firestore.js";

    const config = {
      apiKey: "AIzaSyCDt7n4hoxQlF0BRLWB_bBouO4A35YsZVY",
      authDomain: "mata-virgem.firebaseapp.com",
      projectId: "mata-virgem",
      storageBucket: "mata-virgem.firebasestorage.app",
      messagingSenderId: "351134240123",
      appId: "1:351134240123:web:86a041fee58b856ea3c1de"
    };

    console.log('🔥 Iniciando Firebase...');
    const app = initializeApp(config);
    const db = getFirestore(app);
    console.log('✅ Firebase ok!');

    window.importar = async function() {
      const json = document.getElementById('jsonInput').value.trim();
      const status = document.getElementById('status');
      const btn = document.getElementById('btn');

      if (!json) {
        mostrar('Cole o JSON!', 'error');
        return;
      }

      btn.disabled = true;
      mostrar('⏳ Importando...', 'loading');

      try {
        const dados = JSON.parse(json);
        console.log('✅ JSON válido:', dados);

        // Limpar antigos
        console.log('🗑️ Limpando dados antigos...');
        const evts = await getDocs(collection(db, 'eventos'));
        for (const d of evts.docs) await deleteDoc(d.ref);

        const gals = await getDocs(collection(db, 'galeria'));
        for (const d of gals.docs) await deleteDoc(d.ref);

        // Eventos
        if (dados.eventos && Array.isArray(dados.eventos)) {
          console.log('📝 Importando', dados.eventos.length, 'eventos');
          for (const e of dados.eventos) {
            await setDoc(doc(db, 'eventos', e.id || Date.now().toString()), {
              dia: e.dia, mes: e.mes, semana: e.semana, nome: e.nome, hora: e.hora
            });
          }
        }

        // Próxima
        if (dados.proximaGira && typeof dados.proximaGira === 'object') {
          console.log('🎭 Importando próxima gira');
          await setDoc(doc(db, 'proximaGira', 'gira1'), dados.proximaGira);
        }

        // Galeria
        if (dados.galeria && Array.isArray(dados.galeria)) {
          console.log('📸 Importando', dados.galeria.length, 'fotos');
          for (const f of dados.galeria) {
            await setDoc(doc(db, 'galeria', f.id || Date.now().toString()), f);
          }
        }

        // Cursos
        if (dados.cursos && Array.isArray(dados.cursos)) {
          console.log('📚 Importando cursos');
          await setDoc(doc(db, 'cursos', 'curso1'), { aulas: dados.cursos[0]?.aulas || [] });
        }

        btn.disabled = false;
        mostrar('✅ Importado com sucesso! Acesse admin.html', 'success');
        setTimeout(() => document.getElementById('jsonInput').value = '', 1000);

      } catch (e) {
        btn.disabled = false;
        console.error('❌ Erro:', e);
        mostrar('❌ Erro: ' + e.message, 'error');
      }
    };

    function mostrar(msg, tipo) {
      const s = document.getElementById('status');
      s.innerHTML = msg;
      s.className = 'status show status-' + tipo;
    }
  </script>

</body>
</html>
